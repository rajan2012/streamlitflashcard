# Copy this file to  .streamlit/secrets.toml  and fill in real values.
# secrets.toml is gitignored, so it never reaches GitHub.
# On Streamlit Cloud you paste this same TOML into Settings → Secrets instead.

[aws]
AWS_ACCESS_KEY_ID = "your-access-key-id"
AWS_SECRET_ACCESS_KEY = "your-secret-access-key"
AWS_DEFAULT_REGION = "eu-north-1"
S3_BUCKET = "test22-rajan"
S3_KEY = "german.csv"

# Optional — only if your CSV headers aren't literally german/english
GERMAN_COLUMN = "german"
ENGLISH_COLUMN = "english"
