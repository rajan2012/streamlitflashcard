# ── AWS credentials ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=eu-central-1

# ── Where your CSV lives in S3 ────────────────────────────────────
# For s3://my-vocab-bucket/decks/german.csv  ->  bucket + key below
S3_BUCKET=my-vocab-bucket
S3_KEY=decks/german.csv

# ── Optional: change only if your CSV headers are not german/english
GERMAN_COLUMN=german
ENGLISH_COLUMN=english

# Seconds to cache the CSV in memory before re-downloading from S3
CACHE_TTL_SECONDS=600
